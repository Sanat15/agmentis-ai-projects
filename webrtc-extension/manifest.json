{
  "manifest_version": 3,
  "name": "WebRTC Demo Extension",
  "version": "2.0",
  "description": "Tab capture + WebRTC calling demo",
  "permissions": [
    "tabs",
    "activeTab",
    "tabCapture"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}